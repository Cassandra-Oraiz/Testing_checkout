@{
    Layout = "_Layout";
    ViewData["Title"] = "My Courses";
}
<div class="page-header">
    <div>
        <h4><i class="bi bi-journal-bookmark-fill"></i> My Enrolled Courses</h4>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Student/Profile">Profile</a></li>
            <li class="breadcrumb-item active">My Courses</li>
        </ol>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#enrollModal">
        <i class="bi bi-plus-circle"></i> Enroll in Course
    </button>
</div>

<div class="card">
    <div class="card-header">
        <div class="card-header-title"><i class="bi bi-list-ul"></i> Enrolled Courses</div>
    </div>
    <div class="table-wrapper">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Course Code</th>
                    <th>Course Name</th>
                    <th>Credits</th>
                    <th>Teacher</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="enrolledBody"></tbody>
        </table>
    </div>
</div>

<!-- Enroll Modal -->
<div class="modal fade" id="enrollModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle"></i> Enroll in Course</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Course Name</label>
                    <input type="text" class="form-control" id="newCourseName" placeholder="e.g. Web Development" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Course Code</label>
                    <input type="text" class="form-control" id="newCourseCode" placeholder="e.g. WEB101" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Credits</label>
                    <input type="number" class="form-control" id="newCourseCredits" value="3" min="1" max="6" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Teacher</label>
                    <input type="text" class="form-control" id="newCourseTeacher" placeholder="e.g. Mr. Santos" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-success" id="enrollBtn"><i class="bi bi-check-lg"></i> Enroll</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var enrolled = [
            { id:1, code:'PROG1', name:'Programming 1',     credits:3, teacher:'Mr. Garcia'  },
            { id:2, code:'DS101', name:'Data Structures',   credits:3, teacher:'Ms. Santos'  },
            { id:3, code:'WEB1',  name:'Web Development',   credits:3, teacher:'Mr. Reyes'   },
        ];
        var nextCid = 4;

        function renderEnrolled() {
            var html = '';
            if (!enrolled.length) {
                html = '<tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-inbox" style="font-size:2rem;display:block;opacity:.3;"></i>No enrolled courses.</td></tr>';
            } else {
                enrolled.forEach(function (c, i) {
                    html += '<tr><td>'+(i+1)+'</td>' +
                        '<td><span class="badge" style="background:#DBEAFE;color:var(--accent);padding:5px 10px;border-radius:6px;">'+c.code+'</span></td>' +
                        '<td>'+c.name+'</td><td>'+c.credits+' units</td><td>'+c.teacher+'</td>' +
                        '<td><button class="btn btn-sm btn-outline-danger btn-icon drop-btn" data-id="'+c.id+'" data-name="'+c.name+'" title="Drop"><i class="bi bi-trash3"></i></button></td></tr>';
                });
            }
            $('#enrolledBody').html(html);
        }

        $(function () {
            renderEnrolled();

            $('#enrollBtn').on('click', function () {
                var name    = $('#newCourseName').val().trim();
                var code    = $('#newCourseCode').val().trim();
                var credits = $('#newCourseCredits').val();
                var teacher = $('#newCourseTeacher').val().trim();
                if (!name || !code) { showToast('Course name and code required.', 'warning'); return; }
                enrolled.push({ id: nextCid++, code: code, name: name, credits: credits, teacher: teacher || 'TBA' });
                renderEnrolled();
                $('#enrollModal').modal('hide');
                $('#newCourseName,#newCourseCode,#newCourseTeacher').val('');
                $('#newCourseCredits').val('3');
                showToast('Enrolled successfully.', 'success');
            });

            $(document).on('click', '.drop-btn', function () {
                var id   = parseInt($(this).data('id'));
                var name = $(this).data('name');
                confirmDelete(name, function () {
                    enrolled = enrolled.filter(function (c) { return c.id !== id; });
                    renderEnrolled();
                    showToast('Course dropped.', 'success');
                });
            });
        });
    </script>
}