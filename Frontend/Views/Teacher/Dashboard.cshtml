@{
    Layout = "_Layout";
    ViewData["Title"] = "Teacher Dashboard";
    var userName = Context.Session.GetString("UserName") ?? "Teacher";
    var userEmail = Context.Session.GetString("UserEmail") ?? "";
    var userId = Context.Session.GetString("UserId") ?? "";
    var userInit = userName.Length > 0 ? userName[0].ToString().ToUpper() : "T";
}
<div class="page-header">
    <div>
        <h4><i class="bi bi-speedometer2"></i> Teacher Dashboard</h4>
        <ol class="breadcrumb"><li class="breadcrumb-item active">Dashboard</li></ol>
    </div>
</div>
<div class="row g-4 mb-4">
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon green"><i class="bi bi-people"></i></div><div><div class="stat-label">Total Students</div><div class="stat-value" id="statMyStudents">—</div></div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon blue"><i class="bi bi-check-circle"></i></div><div><div class="stat-label">Present Today</div><div class="stat-value" id="statPresent">—</div></div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon red"><i class="bi bi-x-circle"></i></div><div><div class="stat-label">Absent Today</div><div class="stat-value" id="statAbsent">—</div></div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon orange"><i class="bi bi-clock"></i></div><div><div class="stat-label">Late Today</div><div class="stat-value" id="statLate">—</div></div></div></div>
</div>
<div class="row g-3">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <div class="card-header-title"><i class="bi bi-people-fill"></i> Students</div>
                <div class="search-bar"><i class="bi bi-search"></i><input type="text" class="form-control" id="tSearch" placeholder="Search..."></div>
            </div>
            <div class="table-wrapper">
                <table class="table table-striped">
                    <thead><tr><th>#</th><th>Name</th><th>Email</th><th>Gender</th><th>Year</th></tr></thead>
                    <tbody id="tStudentBody"></tbody>
                </table>
            </div>
            <div class="pagination-wrapper"><div id="tStudentPagination"></div></div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card">
            <div class="profile-header">
                <div class="profile-avatar">@userInit</div>
                <div><div class="profile-name">@userName</div><div class="profile-role">Teacher</div></div>
            </div>
            <div class="card-body">
                <div class="info-row"><i class="bi bi-envelope-fill"></i> @userEmail</div>
                <div class="info-row" id="teacherDeptInfo"><i class="bi bi-building"></i> —</div>
                <hr />
                <a href="/Teacher/Attendance" class="btn btn-primary w-100"><i class="bi bi-clipboard2-check-fill"></i> Mark Attendance</a>
                <a href="/Teacher/Profile" class="btn btn-outline-secondary w-100 mt-2"><i class="bi bi-person-circle"></i> My Profile</a>
                <a href="/Login/Logout" class="btn btn-outline-danger w-100 mt-2"><i class="bi bi-box-arrow-right"></i> Logout</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var allStudents=[], allUsers=[], tPg;
        var currentUserId = '@userId';

        $(function(){
            // Load teacher dept info
            if (currentUserId) {
                $.ajax({ url: '/api/Teacher', dataType: 'json',
                    success: function(teachers) {
                        var t = (Array.isArray(teachers)?teachers:[]).find(function(x){ return (x.user_ID||x.userId)==currentUserId; });
                        if (t && t.department) $('#teacherDeptInfo').html('<i class="bi bi-building"></i> '+t.department);
                    }
                });
            }

            $.when(
                $.ajax({ url: '/api/Student', dataType: 'json' }),
                $.ajax({ url: '/api/User',    dataType: 'json' })
            ).done(function(sRes, uRes){
                allStudents = Array.isArray(sRes[0]) ? sRes[0] : [];
                allUsers    = Array.isArray(uRes[0]) ? uRes[0] : [];
                $('#statMyStudents').text(allStudents.length);
                tPg = paginate({
                    data: allStudents, pageSize: 10, containerId: 'tStudentBody', paginationId: 'tStudentPagination',
                    colSpan: 5, emptyMsg: 'No students.',
                    renderRow: function(s, i){
                        var u = allUsers.find(function(x){ return x.user_ID==(s.user_ID||s.userId); })||{};
                        var name=u.full_Name||'—', init=(name[0]||'?').toUpperCase();
                        var gender=u.gender==='M'?'Male':u.gender==='F'?'Female':'—';
                        var year=s.year_Level||'—';
                        return '<tr><td>'+(i+1)+'</td>'+
                            '<td><div class="d-flex align-items-center gap-2"><div style="width:28px;height:28px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;">'+init+'</div>'+name+'</div></td>'+
                            '<td>'+(u.email||'—')+'</td><td>'+gender+'</td><td>'+year+'</td></tr>';
                    }
                });
            });

            // Today's attendance stats
            var today=new Date().toISOString().slice(0,10);
            $.ajax({ url:'/AttendanceManagement/Attendance', dataType:'json',
                success: function(data){
                    var arr=(Array.isArray(data)?data:[]).filter(function(a){ return (a.date||a.attendanceDate||'').substring(0,10)===today; });
                    $('#statPresent').text(arr.filter(a=>(a.status||'').toLowerCase()==='present').length);
                    $('#statAbsent').text(arr.filter(a=>(a.status||'').toLowerCase()==='absent').length);
                    $('#statLate').text(arr.filter(a=>(a.status||'').toLowerCase()==='late').length);
                }
            });

            $('#tSearch').on('input', function(){
                var q=$(this).val().toLowerCase();
                tPg.refresh(allStudents.filter(function(s){
                    var u=allUsers.find(function(x){ return x.user_ID==(s.user_ID||s.userId); })||{};
                    return (u.full_Name||'').toLowerCase().includes(q)||(u.email||'').toLowerCase().includes(q);
                }));
            });
        });
    </script>
}