@{
    ViewData["Title"] = "Take Attendance";
}
<div class="page-header">
    <div>
        <h4><i class="bi bi-calendar-check"></i> Take Attendance</h4>
        <ol class="breadcrumb"><li class="breadcrumb-item"><a href="/Teacher/Dashboard">Home</a></li><li class="breadcrumb-item active">Attendance</li></ol>
    </div>
    <input type="date" id="attendanceDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" style="width:auto;">
</div>
<div class="row g-4 mb-4">
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon green"><i class="bi bi-check-circle"></i></div><div><div class="stat-label">Present</div><div class="stat-value" id="presentCount">0</div></div></div></div>
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon red"><i class="bi bi-x-circle"></i></div><div><div class="stat-label">Absent</div><div class="stat-value" id="absentCount">0</div></div></div></div>
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon orange"><i class="bi bi-clock"></i></div><div><div class="stat-label">Late</div><div class="stat-value" id="lateCount">0</div></div></div></div>
</div>
<div class="card">
    <div class="card-header">
        <div class="card-header-title"><i class="bi bi-table"></i> Attendance Sheet</div>
        <div class="search-bar"><i class="bi bi-search"></i><input type="text" class="form-control" id="searchStudent" placeholder="Search student..."></div>
    </div>
    <div class="table-wrapper">
        <table class="table table-striped">
            <thead><tr><th>ID</th><th>Name</th><th>Course</th><th>Status</th><th>Hours</th><th>Actions</th></tr></thead>
            <tbody id="attendanceTableBody"></tbody>
        </table>
    </div>
    <div class="pagination-wrapper"><div id="attendancePagination"></div></div>
</div>

@section Scripts {
    <script>
        let attendancePaginator, attendanceData = [], currentDate = '';

        function renderAttendanceRow(r, idx) {
            var sid = r.studentId || r.id;
            var name = r.studentName || r.name || ((r.firstName||'')+(r.lastName||'')).trim();
            var course = r.course || r.courseName || '—';
            var status = r.status || r.statusName || 'absent';
            var hours = r.hours || r.hoursRendered || 0;
            return `<tr>
                <td>${sid}</td><td>${name}</td><td>${course}</td>
                <td><select class="form-select form-select-sm status-select" data-id="${sid}" style="width:120px;">
                    <option value="present" ${status==='present'?'selected':''}>Present</option>
                    <option value="absent"  ${status==='absent' ?'selected':''}>Absent</option>
                    <option value="late"    ${status==='late'   ?'selected':''}>Late</option>
                </select></td>
                <td><input type="number" class="form-control form-control-sm hours-input" data-id="${sid}" value="${hours}" step="0.5" min="0" max="8" style="width:70px;"></td>
                <td><button class="btn btn-sm btn-primary save-attendance" data-id="${sid}">Save</button></td>
            </tr>`;
        }

        function loadAttendance(date) {
            getTeacherAttendance(date, function (data) {
                attendanceData = Array.isArray(data) ? data : (data.data || data.items || []);
                currentDate = date;
                if (attendancePaginator) attendancePaginator.refresh(attendanceData);
                else attendancePaginator = paginate({ data: attendanceData, pageSize: 10, containerId: 'attendanceTableBody', paginationId: 'attendancePagination', renderRow: renderAttendanceRow, emptyMsg: 'No students found.', colSpan: 6 });
                $('#presentCount').text(attendanceData.filter(s=>(s.status||s.statusName)==='present').length);
                $('#absentCount').text(attendanceData.filter(s=>(s.status||s.statusName)==='absent').length);
                $('#lateCount').text(attendanceData.filter(s=>(s.status||s.statusName)==='late').length);
            });
        }

        $(function () {
            let today = new Date().toISOString().slice(0,10);
            loadAttendance(today);
            $('#attendanceDate').change(function () { loadAttendance($(this).val()); });
            $('#searchStudent').on('keyup', function () {
                var q=$(this).val().toLowerCase();
                attendancePaginator.refresh(attendanceData.filter(s=>{
                    var n=s.studentName||s.name||((s.firstName||'')+(s.lastName||''));
                    return n.toLowerCase().includes(q);
                }));
            });
            $(document).on('click', '.save-attendance', function () {
                var id=$(this).data('id');
                markAttendance({ date:currentDate, studentId:id, status:$(`.status-select[data-id="${id}"]`).val(), hours:$(`.hours-input[data-id="${id}"]`).val() },
                    function(){ loadAttendance(currentDate); });
            });
        });
    </script>
}