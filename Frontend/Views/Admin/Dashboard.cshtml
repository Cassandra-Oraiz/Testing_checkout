@{
    Layout = "_Layout";
    ViewData["Title"] = "Admin Dashboard";
}
<div class="page-header">
    <div>
        <h4><i class="bi bi-speedometer2"></i> Dashboard</h4>
        <ol class="breadcrumb"><li class="breadcrumb-item active">Dashboard</li></ol>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addStudentModal">
        <i class="bi bi-person-plus"></i> Add Student
    </button>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-people"></i></div>
            <div><div class="stat-label">Total Students</div><div class="stat-value" id="statStudents">—</div></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-person-badge"></i></div>
            <div><div class="stat-label">Total Teachers</div><div class="stat-value" id="statTeachers">—</div></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="bi bi-journal-bookmark-fill"></i></div>
            <div><div class="stat-label">Total Courses</div><div class="stat-value" id="statCourses">—</div></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon red"><i class="bi bi-calendar-x"></i></div>
            <div><div class="stat-label">Absences Today</div><div class="stat-value" id="statAbsences">—</div></div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <div class="card-header-title"><i class="bi bi-table"></i> Population List</div>
        <div class="search-bar">
            <i class="bi bi-search"></i>
            <input type="text" class="form-control" id="searchStudent" placeholder="Search student...">
        </div>
    </div>
    <div class="table-wrapper">
        <table class="table table-striped">
            <thead><tr><th>#</th><th>Name</th><th>Email</th><th>Gender</th><th>Program</th><th>Year</th><th>Actions</th></tr></thead>
            <tbody id="studentTableBody"></tbody>
        </table>
    </div>
    <div class="pagination-wrapper">
        <div class="pagination-info" id="studentInfo"></div>
        <div id="studentPagination"></div>
    </div>
</div>

<!-- Add Student Modal -->
<div class="modal fade" id="addStudentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-plus"></i> Add Student</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <h6 class="text-muted mb-3"><i class="bi bi-person-fill"></i> User Account</h6>
                <div class="row g-2">
                    <div class="col-md-6"><label class="form-label">Full Name <span class="text-danger">*</span></label><input type="text" class="form-control" id="addFullName" placeholder="e.g. Juan Dela Cruz"></div>
                    <div class="col-md-6"><label class="form-label">Email <span class="text-danger">*</span></label><input type="email" class="form-control" id="addEmail" placeholder="student@email.com"></div>
                    <div class="col-md-6"><label class="form-label">Password <span class="text-danger">*</span></label><input type="password" class="form-control" id="addPassword"></div>
                    <div class="col-md-6"><label class="form-label">Phone</label><input type="text" class="form-control" id="addPhone" placeholder="09xxxxxxxxx"></div>
                    <div class="col-md-4">
                        <label class="form-label">Gender</label>
                        <select class="form-select" id="addGender"><option value="M">Male</option><option value="F">Female</option></select>
                    </div>
                    <div class="col-md-4"><label class="form-label">Birth Date</label><input type="date" class="form-control" id="addBirthDate"></div>
                    <div class="col-md-4"><label class="form-label">Address</label><input type="text" class="form-control" id="addAddress"></div>
                </div>
                <hr>
                <h6 class="text-muted mb-3"><i class="bi bi-mortarboard"></i> Student Info</h6>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label class="form-label">Program <span class="text-danger">*</span></label>
                        <select class="form-select" id="addProgramId"><option value="">Loading...</option></select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Department <span class="text-danger">*</span></label>
                        <select class="form-select" id="addDeptId"><option value="">Loading...</option></select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Year Level <span class="text-danger">*</span></label>
                        <select class="form-select" id="addYearLevel">
                            <option value="1st Year">1st Year</option>
                            <option value="2nd Year">2nd Year</option>
                            <option value="3rd Year">3rd Year</option>
                            <option value="4th Year">4th Year</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="saveStudentBtn"><i class="bi bi-check-lg"></i> Save Student</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Student Modal -->
<div class="modal fade" id="editStudentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil"></i> Edit Student</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editUserId">
                <input type="hidden" id="editStudentId">
                <input type="hidden" id="editUserGroupId">
                <h6 class="text-muted mb-3"><i class="bi bi-person-fill"></i> User Account</h6>
                <div class="row g-2">
                    <div class="col-md-6"><label class="form-label">Full Name</label><input type="text" class="form-control" id="editFullName"></div>
                    <div class="col-md-6"><label class="form-label">Email</label><input type="email" class="form-control" id="editEmail"></div>
                    <div class="col-md-6"><label class="form-label">Phone</label><input type="text" class="form-control" id="editPhone"></div>
                    <div class="col-md-3">
                        <label class="form-label">Gender</label>
                        <select class="form-select" id="editGender"><option value="M">Male</option><option value="F">Female</option></select>
                    </div>
                    <div class="col-md-3"><label class="form-label">Birth Date</label><input type="date" class="form-control" id="editBirthDate"></div>
                    <div class="col-md-6"><label class="form-label">Address</label><input type="text" class="form-control" id="editAddress"></div>
                </div>
                <hr>
                <h6 class="text-muted mb-3"><i class="bi bi-mortarboard"></i> Student Info</h6>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label class="form-label">Program</label>
                        <select class="form-select" id="editProgramId"><option value="">Loading...</option></select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Department</label>
                        <select class="form-select" id="editDeptId"><option value="">Loading...</option></select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Year Level</label>
                        <select class="form-select" id="editYearLevel">
                            <option value="1st Year">1st Year</option>
                            <option value="2nd Year">2nd Year</option>
                            <option value="3rd Year">3rd Year</option>
                            <option value="4th Year">4th Year</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="updateStudentBtn"><i class="bi bi-check-lg"></i> Update</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var STUDENT_GROUP_ID = 3;
        var allStudents = [], allUsers = [], allPrograms = [], allDepts = [], pg;

        function toUtcIso(dateVal) {
            if (!dateVal) return new Date().toISOString();
            return new Date(dateVal).toISOString();
        }

        function renderRow(s, i) {
            var user = allUsers.find(function(u){ return u.user_ID == (s.user_ID || s.userId); }) || {};
            var name = user.full_Name || s.full_Name || '—';
            var email = user.email || s.email || '—';
            var gender = user.gender === 'M' ? 'Male' : user.gender === 'F' ? 'Female' : (user.gender || '—');
            var prog = allPrograms.find(function(p){ return p.id == s.program_ID; });
            var progName = prog ? (prog.name || prog.program_Name || prog.title || '') : (s.program_ID ? 'Program #'+s.program_ID : '—');
            var year = s.year_Level || '—';
            var sid = s.student_ID || s.id || s.studentId;
            var uid = s.user_ID || s.userId;
            var ugid = user.userGroup_ID || STUDENT_GROUP_ID;
            return '<tr>' +
                '<td>' + (i+1) + '</td>' +
                '<td><div class="d-flex align-items-center gap-2">' +
                '<div style="width:32px;height:32px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:12px;">' + (name[0]||'?').toUpperCase() + '</div>' +
                name + '</div></td>' +
                '<td>' + email + '</td>' +
                '<td>' + gender + '</td>' +
                '<td>' + progName + '</td>' +
                '<td>' + year + '</td>' +
                '<td class="d-flex gap-1">' +
                '<button class="btn btn-sm btn-outline-primary btn-icon edit-btn" data-sid="' + sid + '" data-uid="' + uid + '" data-ugid="' + ugid + '" title="Edit"><i class="bi bi-pencil"></i></button>' +
                '<button class="btn btn-sm btn-outline-danger btn-icon del-btn" data-sid="' + sid + '" data-uid="' + uid + '" data-name="' + name + '" title="Delete"><i class="bi bi-trash3"></i></button>' +
                '</td></tr>';
        }

        function loadDropdowns(progSelId, deptSelId, selProgId, selDeptId) {
            getPrograms(function(p) {
                allPrograms = p;
                var o = '<option value="">Select Program</option>';
                p.forEach(function(x) {
                    var n = x.name || x.program_Name || x.title || 'Program ' + x.id;
                    o += '<option value="' + x.id + '" ' + (x.id == selProgId ? 'selected' : '') + '>' + n + '</option>';
                });
                $(progSelId).html(o);
            });
            getDepartments(function(d) {
                var o = '<option value="">Select Department</option>';
                d.forEach(function(x) {
                    var n = x.name || x.department_Name || 'Dept ' + x.id;
                    o += '<option value="' + x.id + '" ' + (x.id == selDeptId ? 'selected' : '') + '>' + n + '</option>';
                });
                $(deptSelId).html(o);
            });
        }

        function loadStudents() {
            $.when(
                $.ajax({ url: '/api/Student', dataType: 'json' }),
                $.ajax({ url: '/api/User', dataType: 'json' })
            ).done(function(sRes, uRes) {
                allStudents = Array.isArray(sRes[0]) ? sRes[0] : [];
                allUsers    = Array.isArray(uRes[0]) ? uRes[0] : [];
                if (pg) pg.refresh(allStudents);
                else pg = paginate({
                    data: allStudents, pageSize: 10,
                    containerId: 'studentTableBody', paginationId: 'studentPagination',
                    colSpan: 7, emptyMsg: 'No students found.', renderRow: renderRow
                });
                $('#statStudents').text(allStudents.length);
            }).fail(function() { showToast('Failed to load students.', 'error'); });
        }

        $(function () {
            loadStudents();
            getDashboardStats();

            $('#addStudentModal').on('show.bs.modal', function() {
                loadDropdowns('#addProgramId', '#addDeptId', null, null);
            });

            $('#searchStudent').on('input', function () {
                var q = $(this).val().toLowerCase();
                pg.refresh(allStudents.filter(function(s) {
                    var user = allUsers.find(function(u){ return u.user_ID == (s.user_ID||s.userId); }) || {};
                    return (user.full_Name||'').toLowerCase().includes(q) ||
                           (user.email||'').toLowerCase().includes(q);
                }));
            });

            $('#saveStudentBtn').on('click', function () {
                var fullName = $('#addFullName').val().trim();
                var email    = $('#addEmail').val().trim();
                var password = $('#addPassword').val().trim();
                var deptId   = $('#addDeptId').val();
                var yearLvl  = $('#addYearLevel').val();

                if (!fullName) { showToast('Full name is required.', 'warning'); return; }
                if (!email)    { showToast('Email is required.', 'warning'); return; }
                if (!password) { showToast('Password is required.', 'warning'); return; }
                if (!deptId)   { showToast('Department is required.', 'warning'); return; }

                var userData = {
                    full_Name:    fullName,
                    email:        email,
                    password:     password,
                    phone_Number: $('#addPhone').val().trim(),
                    gender:       $('#addGender').val(),
                    birth_Date:   toUtcIso($('#addBirthDate').val()),
                    address:      $('#addAddress').val().trim(),
                    userGroup_ID: STUDENT_GROUP_ID,
                    createdBy:    'admin',
                    lastUpdatedBy:'admin'
                };
                var studentData = {
                    program_ID:    parseInt($('#addProgramId').val()) || 0,
                    department_ID: parseInt(deptId),
                    year_Level:    yearLvl,
                    lastUpdatedBy: 'admin'
                };
                addStudent(userData, studentData, function () {
                    $('#addStudentModal').modal('hide');
                    $('#addFullName,#addEmail,#addPassword,#addPhone,#addAddress').val('');
                    loadStudents();
                });
            });

            $(document).on('click', '.edit-btn', function () {
                var sid  = $(this).data('sid');
                var uid  = $(this).data('uid');
                var ugid = $(this).data('ugid');
                var s = allStudents.find(function(x){ return (x.student_ID||x.id||x.studentId) == sid; }) || {};
                var u = allUsers.find(function(x){ return x.user_ID == uid; }) || {};

                $('#editStudentId').val(sid);
                $('#editUserId').val(uid);
                $('#editUserGroupId').val(ugid || STUDENT_GROUP_ID);
                $('#editFullName').val(u.full_Name||'');
                $('#editEmail').val(u.email||'');
                $('#editPhone').val(u.phone_Number||'');
                $('#editGender').val(u.gender||'M');
                $('#editBirthDate').val((u.birth_Date||'').substring(0,10));
                $('#editAddress').val(u.address||'');
                $('#editYearLevel').val(s.year_Level||'1st Year');
                loadDropdowns('#editProgramId', '#editDeptId', s.program_ID, s.department_ID);
                $('#editStudentModal').modal('show');
            });

            $('#updateStudentBtn').on('click', function () {
                var uid  = $('#editUserId').val();
                var sid  = $('#editStudentId').val();
                var ugid = parseInt($('#editUserGroupId').val()) || STUDENT_GROUP_ID;

                if (!$('#editFullName').val().trim()) { showToast('Full name is required.', 'warning'); return; }

                var userData = {
                    user_ID:      parseInt(uid),
                    full_Name:    $('#editFullName').val().trim(),
                    email:        $('#editEmail').val().trim(),
                    password:     'unchanged',
                    phone_Number: $('#editPhone').val().trim(),
                    gender:       $('#editGender').val(),
                    birth_Date:   toUtcIso($('#editBirthDate').val()),
                    address:      $('#editAddress').val().trim(),
                    userGroup_ID: ugid,
                    lastUpdatedBy:'admin'
                };
                var studentData = {
                    program_ID:    parseInt($('#editProgramId').val()) || 0,
                    department_ID: parseInt($('#editDeptId').val()) || 0,
                    year_Level:    $('#editYearLevel').val(),
                    lastUpdatedBy: 'admin'
                };
                updateStudent(uid, userData, sid, studentData, function () {
                    $('#editStudentModal').modal('hide');
                    loadStudents();
                });
            });

            $(document).on('click', '.del-btn', function () {
                var sid  = $(this).data('sid');
                var uid  = $(this).data('uid');
                var name = $(this).data('name');
                confirmDelete(name, function () { deleteStudent(uid, sid, loadStudents); });
            });
        });
    </script>
}