@{
    ViewData["Title"] = "Attendance History";
}
<div class="page-header">
    <div>
        <h4><i class="bi bi-clock-history"></i> Attendance History</h4>
        <ol class="breadcrumb"><li class="breadcrumb-item"><a href="/Admin/Dashboard">Home</a></li><li class="breadcrumb-item active">History</li></ol>
    </div>
</div>
<div class="filter-bar">
    <label>From</label><input type="date" id="fromDate" class="form-control form-control-sm" style="width:150px;">
    <label>To</label><input type="date" id="toDate" class="form-control form-control-sm" style="width:150px;">
    <label>Status</label>
    <select id="filterStatus" class="form-select form-select-sm" style="width:130px;">
        <option value="">All</option>
        <option value="Present">Present</option>
        <option value="Absent">Absent</option>
        <option value="Late">Late</option>
    </select>
    <button class="btn btn-primary btn-sm" id="applyFilter"><i class="bi bi-funnel"></i> Apply</button>
    <button class="btn btn-outline-secondary btn-sm" id="exportHistory"><i class="bi bi-download"></i> CSV</button>
    <button class="btn btn-outline-secondary btn-sm" id="printHistory"><i class="bi bi-printer"></i> Print</button>
</div>
<div class="card">
    <div class="table-wrapper">
        <table class="table table-striped">
            <thead><tr><th>ID</th><th>Enrollment ID</th><th>Date</th><th>Status</th></tr></thead>
            <tbody id="historyTableBody"></tbody>
        </table>
    </div>
    <div class="pagination-wrapper"><div id="historyPagination"></div></div>
</div>

@section Scripts {
    <script>
        let historyPaginator, historyData=[];

        function renderHistoryRow(r, idx){
            var cls=(r.status||'').toLowerCase()==='present'?'badge-present':(r.status||'').toLowerCase()==='absent'?'badge-absent':'badge-late';
            var date=(r.date||r.attendanceDate||'').substring(0,10);
            return `<tr><td>${r.attendance_ID||r.id}</td><td>${r.enrollment_ID||'—'}</td><td>${date}</td><td><span class="badge ${cls}">${r.status||'—'}</span></td></tr>`;
        }

        function applyFilter(){
            var from=$('#fromDate').val(), to=$('#toDate').val(), status=$('#filterStatus').val();
            getAttendanceHistory({from,to,status}, function(data){
                historyData=data;
                if(historyPaginator) historyPaginator.refresh(historyData);
                else historyPaginator=paginate({data:historyData,pageSize:15,containerId:'historyTableBody',paginationId:'historyPagination',renderRow:renderHistoryRow,emptyMsg:'No records found.',colSpan:4});
            });
        }

        $(function(){
            var today=new Date().toISOString().slice(0,10);
            var first=new Date(new Date().getFullYear(),new Date().getMonth(),1).toISOString().slice(0,10);
            $('#fromDate').val(first); $('#toDate').val(today);

            $('#applyFilter').click(applyFilter);

            $('#exportHistory').click(function(){
                exportCSV('attendance_history',['ID','Enrollment ID','Date','Status'],
                    historyData.map(r=>[r.attendance_ID||r.id, r.enrollment_ID||'', (r.date||r.attendanceDate||'').substring(0,10), r.status||'']));
            });
            $('#printHistory').click(function(){
                printTable('Attendance History',['ID','Enrollment ID','Date','Status'],
                    historyData.map(r=>[r.attendance_ID||r.id, r.enrollment_ID||'', (r.date||r.attendanceDate||'').substring(0,10), r.status||'']));
            });

            applyFilter();
        });
    </script>
}