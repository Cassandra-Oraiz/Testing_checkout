@{
    ViewData["Title"] = "Daily Attendance";
}
<div class="page-header">
    <div>
        <h4><i class="bi bi-calendar-check"></i> Daily Attendance</h4>
        <ol class="breadcrumb"><li class="breadcrumb-item"><a href="/Admin/Dashboard">Home</a></li><li class="breadcrumb-item active">Attendance</li></ol>
    </div>
    <input type="date" id="attendanceDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" style="width:auto;">
</div>
<div class="row g-4 mb-4">
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon green"><i class="bi bi-check-circle"></i></div><div><div class="stat-label">Present</div><div class="stat-value" id="presentCount">0</div></div></div></div>
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon red"><i class="bi bi-x-circle"></i></div><div><div class="stat-label">Absent</div><div class="stat-value" id="absentCount">0</div></div></div></div>
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon orange"><i class="bi bi-clock"></i></div><div><div class="stat-label">Late</div><div class="stat-value" id="lateCount">0</div></div></div></div>
</div>
<div class="card">
    <div class="card-header">
        <div class="card-header-title"><i class="bi bi-table"></i> Attendance Sheet</div>
        <div class="d-flex gap-2">
            <div class="search-bar"><i class="bi bi-search"></i><input type="text" class="form-control" id="searchAttendance" placeholder="Search student..."></div>
            <button class="btn btn-success btn-sm" id="addAttendanceBtn"><i class="bi bi-plus-circle"></i> Add</button>
        </div>
    </div>
    <div class="table-wrapper">
        <table class="table table-striped">
            <thead><tr><th>ID</th><th>Enrollment</th><th>Date</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody id="attendanceTableBody"></tbody>
        </table>
    </div>
    <div class="pagination-wrapper"><div id="attendancePagination"></div></div>
</div>

<!-- Add/Edit Attendance Modal -->
<div class="modal fade" id="attendanceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="attendanceModalTitle"><i class="bi bi-calendar-plus"></i> Add Attendance</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="attendanceId">
                <div class="mb-2">
                    <label class="form-label">Enrollment ID <span class="text-danger">*</span></label>
                    <select class="form-select" id="enrollmentId"></select>
                </div>
                <div class="mb-2">
                    <label class="form-label">Date <span class="text-danger">*</span></label>
                    <input type="date" class="form-control" id="attendanceDateInput">
                </div>
                <div class="mb-2">
                    <label class="form-label">Status <span class="text-danger">*</span></label>
                    <select class="form-select" id="attendanceStatus">
                        <option value="Present">Present</option>
                        <option value="Absent">Absent</option>
                        <option value="Late">Late</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveAttendanceBtn">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let attendancePaginator, attendanceData=[], currentDate='', allEnrollments=[];

        function renderAttendanceRow(r, idx) {
            var rid = r.attendance_ID || r.id;
            var eid = r.enrollment_ID || r.enrollmentId || '—';
            var date = (r.date||r.attendanceDate||'').substring(0,10);
            var status = r.status||'—';
            var cls = status.toLowerCase()==='present'?'badge-present':status.toLowerCase()==='absent'?'badge-absent':'badge-late';
            return `<tr>
                <td>${rid}</td><td>${eid}</td><td>${date}</td>
                <td><span class="badge ${cls}">${status}</span></td>
                <td class="d-flex gap-1">
                    <button class="btn btn-sm btn-outline-primary edit-att" data-id="${rid}"><i class="bi bi-pencil"></i></button>
                    <button class="btn btn-sm btn-outline-danger del-att" data-id="${rid}" data-name="Record #${rid}"><i class="bi bi-trash"></i></button>
                </td></tr>`;
        }

        function loadAttendance(date) {
            getAttendance(date, function(data){
                attendanceData=data; currentDate=date;
                if(attendancePaginator) attendancePaginator.refresh(attendanceData);
                else attendancePaginator=paginate({data:attendanceData,pageSize:10,containerId:'attendanceTableBody',paginationId:'attendancePagination',renderRow:renderAttendanceRow,emptyMsg:'No attendance records found.',colSpan:5});
                $('#presentCount').text(attendanceData.filter(s=>(s.status||'').toLowerCase()==='present').length);
                $('#absentCount').text(attendanceData.filter(s=>(s.status||'').toLowerCase()==='absent').length);
                $('#lateCount').text(attendanceData.filter(s=>(s.status||'').toLowerCase()==='late').length);
            });
        }

        function loadEnrollmentDropdown(selId) {
            getEnrollments(function(data){
                allEnrollments=data;
                var opts='<option value="">Select Enrollment</option>';
                data.forEach(function(e){ var eid=e.enrollment_ID||e.id; opts+='<option value="'+eid+'" '+(eid==selId?'selected':'')+'>Enrollment #'+eid+' (Student:'+e.student_ID+')</option>'; });
                $('#enrollmentId').html(opts);
            });
        }

        $(function(){
            var today=new Date().toISOString().slice(0,10);
            $('#attendanceDate').val(today);
            loadAttendance(today);

            $('#attendanceDate').change(function(){ loadAttendance($(this).val()); });

            $('#searchAttendance').on('keyup',function(){
                var q=$(this).val().toLowerCase();
                attendancePaginator.refresh(attendanceData.filter(r=>(r.status||'').toLowerCase().includes(q)||String(r.enrollment_ID||'').includes(q)));
            });

            $('#addAttendanceBtn').click(function(){
                $('#attendanceModalTitle').html('<i class="bi bi-calendar-plus"></i> Add Attendance');
                $('#attendanceId').val('');
                $('#attendanceDateInput').val(new Date().toISOString().slice(0,10));
                $('#attendanceStatus').val('Present');
                loadEnrollmentDropdown(null);
                $('#attendanceModal').modal('show');
            });

            $('#saveAttendanceBtn').click(function(){
                var id=$('#attendanceId').val();
                var eid=$('#enrollmentId').val();
                var date=$('#attendanceDateInput').val();
                var status=$('#attendanceStatus').val();
                if(!eid){ showToast('Enrollment is required.','warning'); return; }
                if(!date){ showToast('Date is required.','warning'); return; }
                var data={ enrollment_ID:parseInt(eid), date:new Date(date).toISOString(), status:status, lastUpdatedBy:'admin' };
                if(id){
                    updateAttendance(id, data, function(){ $('#attendanceModal').modal('hide'); loadAttendance(currentDate); });
                } else {
                    markAttendance(data, function(){ $('#attendanceModal').modal('hide'); loadAttendance(currentDate); });
                }
            });

            $(document).on('click','.edit-att',function(){
                var id=$(this).data('id');
                var r=attendanceData.find(function(x){ return (x.attendance_ID||x.id)==id; })||{};
                $('#attendanceModalTitle').html('<i class="bi bi-pencil"></i> Edit Attendance');
                $('#attendanceId').val(id);
                $('#attendanceDateInput').val((r.date||r.attendanceDate||'').substring(0,10));
                $('#attendanceStatus').val(r.status||'Present');
                loadEnrollmentDropdown(r.enrollment_ID);
                $('#attendanceModal').modal('show');
            });

            $(document).on('click','.del-att',function(){
                var id=$(this).data('id'), name=$(this).data('name');
                confirmDelete(name, function(){
                    $.ajax({ type:'DELETE', url:'/AttendanceManagement/Attendance/'+id, dataType:'json',
                        beforeSend: function(){ $('#page-loader').fadeIn(150); },
                        success: function(){ $('#page-loader').fadeOut(200); showToast('Attendance deleted.','success'); loadAttendance(currentDate); },
                        error: function(x){ $('#page-loader').fadeOut(200); showToast('Delete failed.','error'); }
                    });
                });
            });
        });
    </script>
}